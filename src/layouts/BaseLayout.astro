---
interface Props {
  title?: string;
  themeClass?: string;
}
const { title = 'One Minute Insights — Concepts that actually stick', themeClass = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&family=Funnel+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style is:global>
    @import '../styles/global.css';
    @import '../styles/themes/blue.css';
    @import '../styles/themes/amber.css';
    @import '../styles/themes/violet.css';
    @import '../styles/themes/rose.css';
    @import '../styles/themes/red.css';
    @import '../styles/themes/cyan.css';
    @import '../styles/themes/teal.css';
  </style>
</head>
<body class={themeClass}>
  <div class="app">
    <slot />
  </div>
</body>
</html>
