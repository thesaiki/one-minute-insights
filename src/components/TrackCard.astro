---
interface Props {
  id: string;
  theme: string;
  number: string;
  title: string;
  tagline: string;
  cornerEmoji: string;
  pills: string[];
  conceptCount: number;
}
const { id, theme, number, title, tagline, cornerEmoji, pills, conceptCount } = Astro.props;
---
<a href={`/tracks/${id}`} class={`track-card ${theme}`} data-track={id}>
  <span class="corner-emoji">{cornerEmoji}</span>
  <div class="track-num">{number}</div>
  <h2>{title}</h2>
  <p>{tagline}</p>
  <div class="pills">
    {pills.map(p => <span class="pill">{p}</span>)}
  </div>
  <div class="track-foot">
    <span class="track-count">{conceptCount} concepts</span>
    <span class="start-btn">Start &rarr;</span>
  </div>
</a>
