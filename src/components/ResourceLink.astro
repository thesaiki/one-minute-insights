---
interface Props {
  title: string;
  meta: string;
  tag: string;
  url?: string;
}
const { title, meta, tag, url } = Astro.props;
const Tag = url ? 'a' : 'div';
---
<Tag class="resource-link" {...(url ? { href: url, target: "_blank", rel: "noopener noreferrer" } : {})}>
  <div class="resource-info">
    <div class="resource-title">{title}</div>
    <div class="resource-meta">{meta}</div>
  </div>
  <span class={`resource-tag ${tag}`}>{tag.toUpperCase()}</span>
</Tag>
